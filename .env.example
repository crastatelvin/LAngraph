# Core
DATABASE_URL=sqlite:///./ai_parliament.db

# API security and limits
MAX_REQUESTS_PER_MINUTE=240
MAX_REQUEST_BODY_BYTES=16384
PLAN_LIMIT_WINDOW_HOURS=24
PLAN_LIMIT_DEFAULTS_JSON={"plan":"pro","limits":{"debate_create_per_day":10000,"agent_outcome_ingest_per_day":10000,"chain_anchor_requests_per_day":10000}}
PLAN_LIMIT_OVERRIDES_JSON={}

# Slack integrations
ENABLE_SLACK_INTEGRATION=false
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_OUTBOUND_FLUSH_INTERVAL_SECONDS=5
FEDERATION_SLACK_CHANNEL=

# Optional observability/service metadata
OTEL_SERVICE_NAME=ai-parliament-api

# Chain anchoring queue worker
CHAIN_QUEUE_FLUSH_INTERVAL_SECONDS=5
CHAIN_QUEUE_MAX_ITEMS=20
